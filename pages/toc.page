      fontSize: 14
      fontFamily: "Inter"
      color: "$lightGray"
      align: [left, middle]
      wrap: false
      text: |
        <p>Vercel CI/CD, accessibility audits, monitoring</p>

  - elementId: divider-line
    elementType: shape
    bounds: [80, 500, 1120, 1]
