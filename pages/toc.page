    fill:
      type: solid
      color: "#374151"

  - elementId: footer-tech
    elementType: text
    bounds: [80, 520, 500, 20]
    content:
      fontSize: 12
      fontFamily: "Inter"
      color: "$lightGray"
      align: [left, middle]
      wrap: false
      text: |
        <p>React 19 + Vite + Tailwind CSS + Framer Motion</p>

  - elementId: footer-date
    elementType: text
    bounds: [900, 520, 300, 20]
    content:
      fontSize: 12
      fontFamily: "Inter"
      color: "$lightGray"
      align: [right, middle]
      wrap: false
      text: |
        <p>Design &amp; Architecture Plan</p>
