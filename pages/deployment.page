    bounds: [660, 385, 560, 100]
    content:
      fontSize: 15
      fontFamily: "Inter"
      color: "$text"
      lineHeight: 1.6
      align: [left, top]
      text: |
        <ul>
        <li>Vercel Dashboard analytics and logs</li>
        <li>Performance monitoring for regressions</li>
        <li>Dependency maintenance schedule</li>
        </ul>

  - elementId: tools-bg
    elementType: shape
    bounds: [60, 510, 1160, 140]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
