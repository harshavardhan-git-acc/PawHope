    fill:
      type: solid
      color: "$borderLight"

  - elementId: col1-bg
    elementType: shape
    bounds: [60, 125, 270, 270]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "$borderLight"

  - elementId: col1-icon
    elementType: icon
    bounds: [80, 145, 32, 32]
