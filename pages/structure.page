pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: brand-mark
    elementType: text
    bounds: [60, 24, 120, 18]
    content:
      fontSize: 12
      fontFamily: "Poppins"
      color: "$lightGray"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
      text: |
        <p>PAWHOPE</p>

  - elementId: accent-bar
    elementType: shape
    bounds: [60, 60, 4, 28]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: page-title
    elementType: text
    bounds: [76, 58, 900, 36]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Site Structure: 8 Pages Driving Engagement</strong></p>

  - elementId: divider-top
